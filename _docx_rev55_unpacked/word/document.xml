    <w:p w14:paraId="36173B73" w14:textId="77777777" w:rsidR="00313BBF" w:rsidRDefault="00E27032">
      <w:pPr>
        <w:spacing w:before="200" w:line="240" w:lineRule="auto"/>
      </w:pPr>
      <w:r>
        <w:t>2.2 Known 불량 분석</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="34508358" w14:textId="77777777" w:rsidR="00313BBF" w:rsidRDefault="00E27032">
      <w:pPr>
        <w:spacing w:after="0" w:line="240" w:lineRule="auto"/>
      </w:pPr>
      <w:r>
        <w:t>등록 불량 경로의 1차 분류기는 ConvNeXtV2-Base이다. 이 모델은 wafer 전역의 위치·형상·배치 문맥을 이용해 16개 클래스를 분류하며, global spatial context가 중요한 결함에서 안정적인 성능을 보였다.</w:t>
      </w:r>
    </w:p>
